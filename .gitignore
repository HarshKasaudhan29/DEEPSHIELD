# ═══════════════════════════════════════════════════════════
# .gitignore — Synthetic Media Detector
# ═══════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────
.env
.env.local
.env.production
*.secret

# ── Java / Maven ─────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
.mvn/
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties
mvnw
mvnw.cmd

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.egg

# ── IDE ───────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── Docker ───────────────────────────────────────────────
.docker/

# ── OS ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
log/

# ── Temp / Upload files ───────────────────────────────────
tmp/
temp/
uploads/

# ── MongoDB data (local dev) ──────────────────────────────
data/

# ── Test reports ─────────────────────────────────────────
test-results/
coverage/
.pytest_cache/
htmlcov/
